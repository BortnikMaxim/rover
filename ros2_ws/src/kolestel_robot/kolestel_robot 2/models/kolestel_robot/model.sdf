<?xml version="1.0"?>
<sdf version="1.9">
  <model name="kolestel_robot">
    <pose>0 0 0 0 0 0</pose>

    <!-- =====================
         Parameters (meters)
         ===================== -->
    <!-- From your FeatureScript defaults: wheelbase=0.889m, track=1.0m, wheel_diam=0.4m -->
    <link name="base_link">
      <!-- Keep CoM slightly above ground; tune later -->
      <pose>0 0 0.45 0 0 0</pose>

      <!-- Visual: start with simple box; swap to mesh later -->
      <visual name="base_visual">
        <geometry>
          <box><size>1.014 0.730 0.25</size></box>
        </geometry>
      </visual>

      <!-- Collision: simple box to keep physics stable -->
      <collision name="base_collision">
        <geometry>
          <box><size>1.014 0.730 0.25</size></box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <!-- Mass/inertia: rough. Replace with better values later -->
      <inertial>
        <mass>25.0</mass>
        <inertia>
          <ixx>1.2</ixx>
          <iyy>2.0</iyy>
          <izz>2.4</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
    </link>

    <!-- Helper: wheel template comment
         Wheel axis is Y (standard: X forward, Y left, Z up). Cylinder axis in SDF is Z,
         so we rotate wheel visuals/collisions by +90deg about X to make axis align with Y. -->

    <!-- Front-left wheel -->
    <link name="front_left_wheel">
      <pose>0.4445 0.5 0.2 0 0 0</pose>
      <visual name="v">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder><radius>0.2</radius><length>0.16</length></cylinder>
        </geometry>
      </visual>
      <collision name="c">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder><radius>0.2</radius><length>0.16</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.02</ixx>
          <iyy>0.04</iyy>
          <izz>0.02</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
    </link>
    <joint name="front_left_wheel_joint" type="revolute">
      
      <pose>0.4445 0.5 0.2 0 0 0</pose>
<parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.1</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <!-- Front-right wheel -->
    <link name="front_right_wheel">
      <pose>0.4445 -0.5 0.2 0 0 0</pose>
      <visual name="v">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder><radius>0.2</radius><length>0.16</length></cylinder>
        </geometry>
      </visual>
      <collision name="c">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder><radius>0.2</radius><length>0.16</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.02</ixx>
          <iyy>0.04</iyy>
          <izz>0.02</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
    </link>
    <joint name="front_right_wheel_joint" type="revolute">
      
      <pose>0.4445 -0.5 0.2 0 0 0</pose>
<parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.1</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <!-- Rear-left wheel -->
    <link name="rear_left_wheel">
      <pose>-0.4445 0.5 0.2 0 0 0</pose>
      <visual name="v">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder><radius>0.2</radius><length>0.16</length></cylinder>
        </geometry>
      </visual>
      <collision name="c">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder><radius>0.2</radius><length>0.16</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.02</ixx>
          <iyy>0.04</iyy>
          <izz>0.02</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
    </link>
    <joint name="rear_left_wheel_joint" type="revolute">
      
      <pose>-0.4445 0.5 0.2 0 0 0</pose>
<parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.1</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <!-- Rear-right wheel -->
    <link name="rear_right_wheel">
      <pose>-0.4445 -0.5 0.2 0 0 0</pose>
      <visual name="v">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder><radius>0.2</radius><length>0.16</length></cylinder>
        </geometry>
      </visual>
      <collision name="c">
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder><radius>0.2</radius><length>0.16</length></cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.02</ixx>
          <iyy>0.04</iyy>
          <izz>0.02</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
    </link>
    <joint name="rear_right_wheel_joint" type="revolute">
      
      <pose>-0.4445 -0.5 0.2 0 0 0</pose>
<parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.1</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <!-- =====================
         Drive system (Gazebo Sim)
         Drives ONLY the front wheels; rears are passive but will spin due to contact.
         ===================== -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <!-- Gazebo Sim DiffDrive supports multiple joints per side -->
        <left_joint>front_left_wheel_joint</left_joint>
        <left_joint>rear_left_wheel_joint</left_joint>
        <right_joint>front_right_wheel_joint</right_joint>
        <right_joint>rear_right_wheel_joint</right_joint>
        <wheel_separation>1.0</wheel_separation>
        <wheel_radius>0.2</wheel_radius>
        <topic>cmd_vel</topic>
        <odometry_topic>odom</odometry_topic>
        <odom_frame>odom</odom_frame>
        <robot_base_frame>base_link</robot_base_frame>
        <max_linear_acceleration>2.0</max_linear_acceleration>
        <max_angular_acceleration>2.5</max_angular_acceleration>
      </plugin>

    <!-- Publish joint states (useful for RViz/Debug) -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher" />

  </model>
</sdf>
