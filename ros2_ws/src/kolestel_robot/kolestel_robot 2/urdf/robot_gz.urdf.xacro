<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="kolestel_robot">

  <!-- If true, visual geometry is loaded from meshes/ (exported from Onshape). -->
  <xacro:arg name="use_meshes" default="false"/>

  <!--
    Main robot description file for Gazebo Sim (Harmonic).
    Combines base robot model with Gazebo Sim plugins.

    Usage:
      xacro robot_gz.urdf.xacro > robot.urdf
  -->

  <!-- Include robot properties -->
  <xacro:include filename="$(find kolestel_robot)/urdf/robot_properties.xacro"/>

  <!-- Include inertia macros -->
  <xacro:include filename="$(find kolestel_robot)/urdf/inertia_macros.xacro"/>

  <!-- Include wheel macro -->
  <xacro:include filename="$(find kolestel_robot)/urdf/wheel.xacro"/>

  <!-- Include sensors (geometry + frames) -->
  <xacro:include filename="$(find kolestel_robot)/urdf/sensors.xacro"/>

  <!-- Include Gazebo Sim plugins -->
  <xacro:include filename="$(find kolestel_robot)/urdf/gz_plugins.xacro"/>

  <!-- ==================== BASE FOOTPRINT ==================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- Put base_link above ground by wheel radius -->
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== BASE LINK (CHASSIS) ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <xacro:if value="$(arg use_meshes)">
          <mesh filename="package://kolestel_robot/meshes/chassis_visual.dae" scale="1 1 1"/>
        </xacro:if>
        <xacro:unless value="$(arg use_meshes)">
          <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
        </xacro:unless>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}"/>
  </link>

  <!-- ==================== ANTENNA MAST ==================== -->
  <link name="antenna_mast_link">
    <visual>
      <origin xyz="0 0 ${antenna_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${mast_radius}" length="${antenna_height}"/>
      </geometry>
      <material name="silver">
        <color rgba="0.8 0.8 0.8 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${antenna_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${mast_radius}" length="${antenna_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${mast_mass}" r="${mast_radius}" h="${antenna_height}"/>
  </link>

  <joint name="antenna_mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="antenna_mast_link"/>
    <origin xyz="${-chassis_length/4} 0 ${chassis_height}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== WHEELS ==================== -->
  <!-- Wheel macro signature: (prefix parent x_pos y_pos) -->
  <xacro:wheel prefix="front_left"  parent="base_link" x_pos="${wheelbase/2}"  y_pos="${track_width/2}"/>
  <xacro:wheel prefix="front_right" parent="base_link" x_pos="${wheelbase/2}"  y_pos="${-track_width/2}"/>
  <xacro:wheel prefix="rear_left"   parent="base_link" x_pos="${-wheelbase/2}" y_pos="${track_width/2}"/>
  <xacro:wheel prefix="rear_right"  parent="base_link" x_pos="${-wheelbase/2}" y_pos="${-track_width/2}"/>

  <!-- ==================== SENSORS ==================== -->
  <xacro:lidar_sensor parent="antenna_mast_link" x_pos="0" y_pos="0" z_pos="${antenna_height + 0.05}"/>

  <xacro:camera_sensor name="camera_front" parent="base_link"
                       x_pos="${chassis_length/2 + 0.02}" y_pos="0" z_pos="${chassis_height/2}"
                       roll="0" pitch="0" yaw="0"/>

  <xacro:camera_sensor name="camera_rear" parent="base_link"
                       x_pos="${-chassis_length/2 - 0.02}" y_pos="0" z_pos="${chassis_height/2}"
                       roll="0" pitch="0" yaw="${pi}"/>

  <!-- Line-follow camera (downward looking). Tune x_pos/z_pos for your track. -->
  <xacro:camera_sensor name="line_camera" parent="base_link"
                       x_pos="${chassis_length/2 - 0.10}" y_pos="0" z_pos="0.12"
                       roll="0" pitch="0" yaw="0"/>

  <xacro:imu_sensor parent="base_link" x_pos="0" y_pos="0" z_pos="${chassis_height}"/>

</robot>
